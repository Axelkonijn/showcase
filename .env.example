# Example van secrets.
# Verwijder .example en vul echte waarden in.
# `.env` staat in .gitignore en mag nooit gecommit worden.

# ---- Database configuratie ----
DB_USER=showcase
# Gebruik een sterk, uniek wachtwoord (geen 'showcase'!)
DB_PASSWORD=CHANGE_ME
DB_NAME=ShowcaseDB

# ---- Mailtrap / SMTP configuratie ----
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# ---- Encryptie sleutel (32-byte sleutel, bv. base64) ----
APP_ENCRYPTION_KEY=CHANGE_ME

# ---- Connection String voor .NET (moet matchen met DB_* hierboven) ----
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=ShowcaseDB;Username=showcase;Password=CHANGE_ME

# ---- E2E Testing ----
E2E_BASE_URL=https://showcase-proxy

# ---- Frontend Web App Config ----
NEXT_PUBLIC_API_URL=/api
