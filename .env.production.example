# Example van secrets.
# Verwijder .example en vul echte waarden in.
# `.env.production` staat in .gitignore en mag nooit gecommit worden.

# ---- Database ----
DB_USER=showcase_prod
DB_PASSWORD=CHANGE_ME_STRONG
DB_NAME=ShowcaseDB
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=ShowcaseDB;Username=showcase_prod;Password=CHANGE_ME_STRONG

# ---- SMTP ----
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# ---- Encryptie ----
APP_ENCRYPTION_KEY=CHANGE_ME

# ---- image-tags voor compose-substitutie ----
# API_IMAGE=ghcr.io/<owner>/showcase-api:<sha-of-tag>
# WEBAPP_IMAGE=ghcr.io/<owner>/showcase-webapp:<sha-of-tag>
